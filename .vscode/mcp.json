{
	"servers": {
		"whatsapp": {
			"command": "C:\\Users\\Kaspis\\AppData\\Local\\Programs\\Python\\Python312\\Scripts\\uv.exe",
			"args": [
				"--directory",
				"D:\\dev\\agent\\whatsapp-mcp\\whatsapp-mcp-server",
				"run",
				"main.py"
			],
			"type": "stdio"
		},
		"viber-agent": {
			"command": "node",
			"args": [
				"dist/index.js"
			],
			"type": "stdio"
		},
		"playwright": {
			"command": "npx",
			"args": [
				"@playwright/mcp@latest",
				"--headless"
			],
			"type": "stdio"
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"brunas-tms": {
			"command": "node",
			"args": [
				"dist/brunas-server.js"
			],
			"type": "stdio"
		},
		"bss-accounting": {
			"command": "node",
			"args": [
				"dist/bss-server.js"
			],
			"type": "stdio",
			"env": {
				"NODE_TLS_REJECT_UNAUTHORIZED": "0"
			}
		}
	},
	"inputs": []
}