    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "openai": "^6.32.0",
    "playwright": "^1.59.0-alpha-1771104257000",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.37",
    "@types/sql.js": "^1.4.10",
    "typescript": "^5.3.3"
  }
