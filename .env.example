# Automation MCP Server Configuration

# Add only the credentials you actually need.
# Uncomment the blocks that apply to your setup.

# Brunas TMS
# BRUNAS_API_URL=https://example.com
# BRUNAS_API_USERNAME=your_login
# BRUNAS_API_PASSWORD=your_password

# BSS Accounting
# BSS_API_URL=https://bss.example.com
# BSS_USERNAME=finance_user
# BSS_PASSWORD=super_secret

# WhatsApp bridge
# WHATSAPP_SESSION_PATH=./whatsapp-mcp/whatsapp-bridge/store

# Optional: LLM Configuration (for smart WhatsApp routing)
# Supports OpenAI, GitHub Models, or any OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
# GitHub Models example:
#   OPENAI_API_KEY=ghp_yourGitHubToken
#   OPENAI_BASE_URL=https://models.inference.ai.azure.com
#   LLM_MODEL=gpt-4o-mini

# Optional: Enable debug logging
DEBUG=false

# Brunas TMS Configuration
BRUNAS_EMAIL=
BRUNAS_PASSWORD=
BRUNAS_CLIENT_URL=https://demo.brunas.lt

# WhatsApp allowed users (only these numbers can use Brunas TMS via WhatsApp)
# Format: phone:Name, phone:Name
ALLOWED_WHATSAPP_USERS=

# WhatsApp poller config
POLL_INTERVAL_MS=5000
WHATSAPP_API_URL=http://localhost:8080
