# Viber Agent MCP Server Configuration

# Your Viber Bot API Token (get from Viber Business Hub)
# https://www.viber.com/en/business/bot
VIBER_BOT_TOKEN=your_viber_bot_token_here

# Webhook URL (where Viber will send messages to your server)
# Example: https://your-domain.com/webhook/viber
WEBHOOK_URL=http://localhost:3001/webhook/viber

# Port for the webhook server (default: 3001)
WEBHOOK_PORT=3001

# Optional: LLM Configuration (if using external LLM)
# LLM_API_KEY=your_llm_api_key
# LLM_MODEL=gpt-4
# LLM_BASE_URL=https://api.openai.com/v1

# Optional: Enable debug logging
DEBUG=false

# Brunas TMS Configuration
BRUNAS_EMAIL=
BRUNAS_PASSWORD=
BRUNAS_CLIENT_URL=https://demo.brunas.lt

# WhatsApp allowed users (only these numbers can use Brunas TMS via WhatsApp)
# Format: phone:Name, phone:Name
ALLOWED_WHATSAPP_USERS=

# WhatsApp poller config
POLL_INTERVAL_MS=5000
WHATSAPP_API_URL=http://localhost:8080
